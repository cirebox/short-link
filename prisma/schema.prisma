generator markdown {
  provider             = "prisma-markdown"
  title                = "Short Link API Database Schema"
  output               = "./ERD.md"
  alphabeticalModels   = true
  includeRelations     = true
  tableOfContents      = true
  includeFieldExamples = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// @namespace user
/// Tabela de usuários do sistema.
/// Cada registro representa um usuário cadastrado na plataforma.
model User {
  /// ID único do usuário, gerado automaticamente em formato UUID.
  id String @id @default(uuid()) @map("_id")

  /// Nome completo do usuário.
  name String

  /// Email do usuário, deve ser único no sistema.
  email String @unique

  /// Senha do usuário, armazenada de forma criptografada.
  password String

  /// Data de criação do registro.
  createdAt DateTime @default(now())

  /// Data da última atualização do registro.
  updatedAt DateTime @updatedAt

  /// URLs encurtadas criadas pelo usuário.
  urls Url[]

  @@map("user")
}

/// @namespace url
/// Tabela de URLs encurtadas.
/// Cada registro representa uma URL original que foi encurtada.
model Url {
  /// ID único da URL, gerado automaticamente em formato UUID.
  id String @id @default(uuid()) @map("_id")

  /// URL original que foi encurtada.
  originalUrl String

  /// Código curto de 6 caracteres para acesso à URL.
  shortCode String @unique

  /// Alias customizado opcional (3-30 caracteres, lowercase alphanumeric + hyphens/underscores).
  alias String? @unique

  /// ID do usuário que criou a URL (opcional para URLs criadas sem autenticação).
  userId String?

  /// Contador de acessos à URL.
  accessCount Int @default(0)

  /// Data de criação do registro.
  createdAt DateTime @default(now())

  /// Data da última atualização do registro.
  updatedAt DateTime @updatedAt

  /// Data de exclusão lógica (soft delete).
  deletedAt DateTime?

  /// Relacionamento com o usuário criador (opcional).
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("url")
}